{
  "env": {{ toPrettyJson .claude.env
    | replace "\r\n" "\n"
    | trimSuffix "\n"
    | replace "\n" "\n  " -}},
  "permissions": {
    "allow": [
      "Bash(./gradlew:*)",
      "Bash(awk:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(docker:*)",
      "Bash(echo:*)",
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(find:*)",
      "Bash(fotingo:*)",
      "Bash(git add:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git commit:*)",
      "Bash(git ls:*)",
      "Bash(git log:*)",
      "Bash(git rebase:*)",
      "Bash(git reset)",
      "Bash(git reset:*)",
      "Bash(git rm:*)",
      "Bash(git show:*)",
      "Bash(git stash:*)",
      "Bash(git status:*)",
      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(go mod tidy:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(golangci-lint:*)",
      "Bash(grep:*)",
      "Bash(kubectl kustomize:*)",
      "Bash(kustomize:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mmdc:*)",
      "Bash(mv:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(openspec:*)",
      "Bash(pre-commit:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(rm:*)",
      "Bash(sed:*)",
      "Bash(terraform init:*)",
      "Bash(terraform fmt:*)",
      "Bash(terraform validate:*)",
      "Bash(wc:*)",
      "Bash(yarn:*)",
      "Skill(openspec-new-change)",
      "Skill(opsx:apply)",
      "Skill(opsx:archive)",
      "WebFetch(domain:github.com)",
      "WebSearch"
    ],
    "deny": []
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "code-simplifier@claude-plugins-official": true,
    "code@tagoro9": true,
    "dx@tagoro9": true,
    "kotlin-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "tagoro9": {
      "source": {
        "source": "github",
        "repo": "tagoro9/dotfiles"
      }
    }
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"$HOME\"/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null || ls -d \"$HOME\"/.claude/plugins/cache/claude-hud/claude-hud/* 2>/dev/null | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1); exec \"/Users/victormora/.local/share/mise/installs/bun/1.3.0/bin/bun\" \"${plugin_dir}/src/index.ts\"'"
  },
  "alwaysThinkingEnabled": true,
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
