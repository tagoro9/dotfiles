{{- $folderPerms := list -}}
{{- range .code.folders -}}
  {{- $folderPerms = append $folderPerms (printf "Edit(%s/**)" .) -}}
  {{- $folderPerms = append $folderPerms (printf "Read(%s/**)" .) -}}
  {{- $folderPerms = append $folderPerms (printf "Write(%s/**)" .) -}}
{{- end -}}
{{- $allPermissions := concat $basePermissions $folderPerms (.claude.extraPermissions | default (list)) | sortAlpha | uniq -}}
{{- $basePlugins := dict
  "claude-hud@claude-hud" true
  "code-simplifier@claude-plugins-official" true
  "code@tagoro9" true
  "kotlin-lsp@claude-plugins-official" true
  "typescript-lsp@claude-plugins-official" true
-}}
{{- range (.claude.extraPlugins | default (list)) -}}
  {{- $basePlugins = set $basePlugins . true -}}
{{- end -}}
{{- $baseMarketplaces := dict
  "claude-hud" (dict "source" (dict "repo" "jarrodwatts/claude-hud" "source" "github"))
  "claude-plugins-official" (dict "source" (dict "repo" "anthropics/claude-plugins-official" "source" "github"))
  "tagoro9" (dict "source" (dict "repo" "tagoro9/dotfiles" "source" "github"))
-}}
{{- $allMarketplaces := mergeOverwrite (dict) $baseMarketplaces (.claude.extraMarketplaces | default (dict)) -}}
{
  "env": {{ toPrettyJson .claude.env
    | replace "\r\n" "\n"
    | trimSuffix "\n"
    | replace "\n" "\n  " -}},
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": {{ toPrettyJson $allPermissions | replace "\r\n" "\n" | trimSuffix "\n" | replace "\n" "\n    " -}},
    "deny": []
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"$HOME\"/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null || ls -d \"$HOME\"/.claude/plugins/cache/claude-hud/claude-hud/* 2>/dev/null | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1); exec \"/Users/victormora/.local/share/mise/installs/bun/1.3.0/bin/bun\" \"${plugin_dir}/src/index.ts\"'"
  },
  "enabledPlugins": {{ toPrettyJson $basePlugins | replace "\r\n" "\n" | trimSuffix "\n" | replace "\n" "\n  " -}},
  "extraKnownMarketplaces": {{ toPrettyJson $allMarketplaces | replace "\r\n" "\n" | trimSuffix "\n" | replace "\n" "\n  " -}},
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "stable"
}
